#!/usr/bin/env python3
"""
skillctl — manage Claude Code skills across any project and marketplace.

The engine behind the skill-manager plugin. The plugin's skills invoke this via
${CLAUDE_PLUGIN_ROOT}/bin/skillctl, and you can also run it straight from a terminal.
Stdlib only, no dependencies. Targets macOS/Linux.

It operates on your *existing local checkout* of a marketplace repo (no second clone),
and adapts to any layout: plugins at the repo root (source "./<name>") or nested in a
monorepo (source "./path/to/plugins/<name>"). Versions live in marketplace.json.

Authoring a skill from scratch is delegated to the native `skill-creator` skill — this
tool only handles the *ops*: configure a project, push skills central, remove them.

Config: ~/.claude/skill-manager.json (written by `skillctl init`).

Subcommands:
  init           One-time setup: point at your checkout, register the marketplace.
  configure      Choose which plugins this project uses (writes settings.local.json).
  enable/disable Toggle a plugin in this project's settings.
  push           Publish a project-local skill central, or sync edits up (auto-detected).
  pull           Copy a central skill down into this project to iterate on it.
  new-plugin     Scaffold a new plugin and register it in the catalog.
  remove-skill   Delete a skill from a central plugin and push the removal.
  remove-plugin  Delete a plugin, unregister it, and push the removal.
  status         Catalog + what's enabled here + a health check (--fix to auto-repair).
  validate       Lint marketplace.json, every plugin.json, and every SKILL.md (CI-friendly).
  refresh        Update the marketplace so a new/changed plugin is picked up.
  version-bump   Patch-bump a plugin's version in marketplace.json.
"""
from __future__ import annotations

import argparse
import filecmp
import json
import os
import re
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path

CONFIG_PATH = Path(os.path.expanduser("~/.claude/skill-manager.json"))
USER_SETTINGS = Path(os.path.expanduser("~/.claude/settings.json"))


# ---------------------------------------------------------------------------
# small utilities
# ---------------------------------------------------------------------------

def die(msg: str, code: int = 1):
    print(f"skillctl: error: {msg}", file=sys.stderr)
    sys.exit(code)


def info(msg: str):
    print(msg)


def warn(msg: str):
    print(f"skillctl: warning: {msg}", file=sys.stderr)


def expand(p: str) -> Path:
    return Path(os.path.expanduser(p)).resolve()


def read_json(path: Path, default=None):
    if not path.exists():
        return default
    try:
        return json.loads(path.read_text())
    except json.JSONDecodeError as e:
        die(f"{path} is not valid JSON: {e}")


def write_json(path: Path, data, backup: bool = True):
    path.parent.mkdir(parents=True, exist_ok=True)
    if backup and path.exists():
        shutil.copy2(path, path.with_suffix(path.suffix + ".bak"))
    path.write_text(json.dumps(data, indent=2) + "\n")


def deep_merge(base: dict, overlay: dict) -> dict:
    """Merge overlay into base without clobbering sibling keys. Dicts merge; everything
    else is replaced. Used so we never destroy existing settings content."""
    out = dict(base)
    for k, v in overlay.items():
        if isinstance(v, dict) and isinstance(out.get(k), dict):
            out[k] = deep_merge(out[k], v)
        else:
            out[k] = v
    return out


def run(cmd: list[str], cwd: Path | None = None, check: bool = True, quiet: bool = False):
    if not quiet:
        info("  $ " + " ".join(cmd))
    res = subprocess.run(cmd, cwd=str(cwd) if cwd else None,
                         capture_output=True, text=True)
    if check and res.returncode != 0:
        die(f"command failed ({res.returncode}): {' '.join(cmd)}\n{res.stderr.strip()}")
    return res


def have(binary: str) -> bool:
    return shutil.which(binary) is not None


# ---------------------------------------------------------------------------
# config + layout resolution (any layout: root-level or nested/monorepo)
# ---------------------------------------------------------------------------

def load_config(required: bool = True) -> dict:
    cfg = read_json(CONFIG_PATH)
    if cfg is None and required:
        die("not configured yet. Run: skillctl init --repo <owner/name> --path <local-checkout>")
    return cfg or {}


def repo_path(cfg: dict) -> Path:
    return expand(cfg["repoPath"])


def plugins_base(cfg: dict) -> Path:
    """Directory under the repo where plugins live. '' or '.' means the repo root."""
    pd = (cfg.get("pluginsDir") or "").strip().strip("/")
    return repo_path(cfg) / pd if pd not in ("", ".") else repo_path(cfg)


def rel_source(cfg: dict, name: str) -> str:
    """The marketplace.json `source` value for a plugin in this layout."""
    pd = (cfg.get("pluginsDir") or "").strip().strip("/")
    return f"./{name}" if pd in ("", ".") else f"./{pd}/{name}"


def marketplace_json_path(cfg: dict) -> Path:
    return repo_path(cfg) / ".claude-plugin" / "marketplace.json"


def catalog(cfg: dict) -> list[dict]:
    mkt = read_json(marketplace_json_path(cfg), {})
    return mkt.get("plugins", []) or []


def _entry(cfg: dict, name: str) -> dict | None:
    for e in catalog(cfg):
        if e.get("name") == name:
            return e
    return None


def plugin_dir(cfg: dict, name: str) -> Path:
    """Resolve a plugin's directory. Prefer the registered source; fall back to the
    configured plugins dir (for a plugin about to be created)."""
    e = _entry(cfg, name)
    if e and e.get("source"):
        src = e["source"]
        rel = src[2:] if src.startswith("./") else src
        return repo_path(cfg) / rel
    return plugins_base(cfg) / name


def plugin_manifest_path(cfg: dict, name: str) -> Path:
    return plugin_dir(cfg, name) / ".claude-plugin" / "plugin.json"


def _find_plugins_for_skill(cfg: dict, skill: str) -> list[str]:
    """Every central plugin that contains a skill of this name. Usually 0 or 1; more than one
    means an ambiguous name the caller must disambiguate with --plugin (we never guess)."""
    return [e["name"] for e in catalog(cfg)
            if (plugin_dir(cfg, e["name"]) / "skills" / skill).exists()]


# ---------------------------------------------------------------------------
# project settings (settings.local.json by default; --shared -> settings.json)
# ---------------------------------------------------------------------------

def project_settings_path(shared: bool = False) -> Path:
    name = "settings.json" if shared else "settings.local.json"
    return Path.cwd() / ".claude" / name


def settings_block(cfg: dict, plugins: list[str]) -> dict:
    mkt = cfg["marketplace"]
    return {
        "extraKnownMarketplaces": {
            mkt: {"source": {"source": "github", "repo": cfg["repoSlug"]}}
        },
        "enabledPlugins": {f"{p}@{mkt}": True for p in plugins},
    }


def apply_settings(path: Path, cfg: dict, enable: list[str] = (), disable: list[str] = ()):
    current = read_json(path, {})
    merged = deep_merge(current, settings_block(cfg, list(enable)))
    mkt = cfg["marketplace"]
    for p in disable:
        merged.setdefault("enabledPlugins", {}).pop(f"{p}@{mkt}", None)
    write_json(path, merged)
    return path


def project_enabled(cfg: dict) -> set[str]:
    out: set[str] = set()
    for p in (project_settings_path(False), project_settings_path(True)):
        s = read_json(p, {})
        for k, on in (s.get("enabledPlugins") or {}).items():
            if on and k.endswith("@" + cfg["marketplace"]):
                out.add(k.split("@")[0])
    return out


# ---------------------------------------------------------------------------
# git (scoped adds, surfaced push failures)
# ---------------------------------------------------------------------------

def _commit_push(cfg: dict, message: str, paths: list[str]) -> bool:
    """Stage only the given paths, commit, push. Returns False (loudly) if push fails so
    the caller can warn the user the change never reached the remote."""
    repo = repo_path(cfg)
    run(["git", "-C", str(repo), "add", "-A", "--"] + [p for p in paths if p])
    res = run(["git", "-C", str(repo), "commit", "-m", message], check=False)
    if res.returncode != 0:
        if "nothing to commit" in (res.stdout + res.stderr):
            info("  (nothing to commit)")
            return True
        die(f"git commit failed:\n{(res.stdout + res.stderr).strip()}")
    # Push the current branch and set upstream — works on a fresh clone with no
    # tracking branch yet (the cold-start case) as well as on an established one.
    branch = run(["git", "-C", str(repo), "rev-parse", "--abbrev-ref", "HEAD"],
                 check=False, quiet=True).stdout.strip() or "HEAD"
    push = run(["git", "-C", str(repo), "push", "-u", "origin", branch], check=False)
    if push.returncode != 0:
        print(f"skillctl: git push failed:\n{push.stderr.strip()}", file=sys.stderr)
        return False
    return True


def _unpushed_count(cfg: dict):
    """How many local commits aren't on origin/<branch> yet (e.g. a previous run committed
    but the push failed). Returns an int, or None if it can't be determined (no upstream ref
    yet). Used to surface stuck pushes without auto-pushing — we never silently push commits
    that may include the user's own unrelated work."""
    repo = repo_path(cfg)
    branch = run(["git", "-C", str(repo), "rev-parse", "--abbrev-ref", "HEAD"],
                 check=False, quiet=True).stdout.strip()
    if not branch or branch == "HEAD":
        return None
    r = run(["git", "-C", str(repo), "rev-list", "--count", f"origin/{branch}..HEAD"],
            check=False, quiet=True)
    if r.returncode != 0:
        return None
    try:
        return int(r.stdout.strip())
    except ValueError:
        return None


# ---------------------------------------------------------------------------
# versioning (marketplace.json only)
# ---------------------------------------------------------------------------

def _bump_version(cfg: dict, plugin: str) -> str:
    mpath = marketplace_json_path(cfg)
    mkt = read_json(mpath, {})
    for e in mkt.get("plugins", []):
        if e.get("name") == plugin:
            parts = ((e.get("version") or "0.0.0").split(".") + ["0", "0", "0"])[:3]
            try:
                parts[2] = str(int(parts[2]) + 1)
            except ValueError:
                parts = ["0", "1", "0"]
            e["version"] = ".".join(parts)
            write_json(mpath, mkt, backup=False)
            return e["version"]
    die(f"plugin '{plugin}' not found in marketplace.json")


def cmd_version_bump(args):
    cfg = load_config()
    info(f"Bumped {args.plugin} -> v{_bump_version(cfg, args.plugin)}.")


# ---------------------------------------------------------------------------
# init
# ---------------------------------------------------------------------------

def _detect_slug(path: Path) -> str | None:
    r = run(["git", "-C", str(path), "remote", "get-url", "origin"], check=False, quiet=True)
    m = re.search(r"[:/]([^/:]+)/([^/]+?)(?:\.git)?$", r.stdout.strip())
    return f"{m.group(1)}/{m.group(2)}" if m else None


def _detect_plugins_dir(mkt: dict) -> str:
    for e in mkt.get("plugins", []):
        src = e.get("source", "")
        rel = src[2:] if src.startswith("./") else src
        return os.path.dirname(rel) or "."
    return "."


def _ensure_registered(cfg: dict):
    """Register the marketplace with Claude Code if it isn't already (idempotent)."""
    if not have("claude"):
        info(f"note: 'claude' CLI not found — register manually: "
             f"/plugin marketplace add {cfg['repoSlug']}")
        return
    ml = run(["claude", "plugin", "marketplace", "list"], check=False, quiet=True)
    if cfg["marketplace"] in (ml.stdout or ""):
        return
    info(f"Registering marketplace '{cfg['marketplace']}' with Claude Code...")
    run(["claude", "plugin", "marketplace", "add", cfg["repoSlug"]], check=False)


def cmd_init(args):
    if not have("git"):
        die("git not found on PATH")
    path = expand(args.path or ".")
    if not (path / ".git").exists():
        if args.repo and "/" in args.repo:
            url = f"https://github.com/{args.repo}.git"
            if path.exists() and any(path.iterdir()):
                die(f"{path} already exists and isn't empty — git won't clone into it.\n"
                    f"Initialize it in place instead (preserves existing files), then re-run "
                    f"with just --path:\n"
                    f"  git -C {path} init -b main && git -C {path} remote add origin {url}\n"
                    f"  skillctl init --path {path}")
            info(f"Cloning {url} -> {path}")
            path.parent.mkdir(parents=True, exist_ok=True)
            r = run(["git", "clone", url, str(path)], check=False)
            if r.returncode != 0:
                die(f"clone failed:\n{r.stderr.strip()}\n"
                    f"If the repo doesn't exist yet, create it first "
                    f"(e.g. `gh repo create {args.repo} --private`), then re-run init.")
        else:
            die(f"{path} is not a git checkout. Pass --path <your local clone>, "
                f"or --repo <owner/name> to clone one there.")

    slug = args.repo or _detect_slug(path)
    if not slug or "/" not in slug:
        die("could not determine the repo slug; pass --repo <owner/name>")

    mkt = read_json(path / ".claude-plugin" / "marketplace.json", {})
    marketplace = args.marketplace or mkt.get("name") or slug.split("/")[-1]
    plugins_dir = args.plugins_dir if args.plugins_dir is not None else _detect_plugins_dir(mkt)
    user_plugins = [p.strip() for p in (args.user_plugins or "").split(",") if p.strip()]

    cfg = {
        "repoPath": str(path),
        "pluginsDir": plugins_dir,
        "marketplace": marketplace,
        "repoSlug": slug,
        "userPlugins": user_plugins,
    }
    write_json(CONFIG_PATH, cfg)
    info(f"Wrote config -> {CONFIG_PATH}")
    info(f"  repo={path}  marketplace={marketplace}  plugins in '{plugins_dir}'")

    # Cold start: make the repo a valid marketplace if it isn't one yet, so it can be
    # registered and have plugins pushed to it immediately.
    mpath = marketplace_json_path(cfg)
    if not mpath.exists():
        write_json(mpath, {"name": marketplace, "owner": {"name": slug.split("/")[0]},
                           "plugins": []}, backup=False)
        info(f"Created {mpath} — this repo is now a marketplace.")
        if not _commit_push(cfg, "Initialize skills marketplace", [str(mpath)]):
            info("WARNING: couldn't push the new marketplace.json (see error above). "
                 "Push it manually so the marketplace is reachable from other machines.")

    if user_plugins:
        apply_settings(USER_SETTINGS, cfg, enable=user_plugins)
        info(f"Enabled {user_plugins} at user scope in {USER_SETTINGS}")

    _ensure_registered(cfg)

    info("\nInit complete.")
    info(f"  • Turn ON auto-update for '{marketplace}' via /plugin -> Marketplaces so new "
         f"sessions pick up changes (otherwise refresh on demand: /plugin marketplace update "
         f"{marketplace}, then /reload-plugins).")
    info("  • Author a skill with the skill-creator skill, then publish it with "
         "/skill-manager:push.")
    info("  • Then /reload-plugins (or start a new session).")


# ---------------------------------------------------------------------------
# configure / enable / disable
# ---------------------------------------------------------------------------

def cmd_configure(args):
    cfg = load_config()
    available = [e["name"] for e in catalog(cfg)]
    if not args.plugins:
        enabled = project_enabled(cfg)
        info("Catalog (pass --plugins to choose what this project enables):\n")
        for e in catalog(cfg):
            mark = "[on] " if e["name"] in enabled else "[  ] "
            info(f"  {mark}{e['name']}  —  {e.get('description', '')}")
        info("\nThen: skillctl configure --plugins a,b,c")
        return
    selected = [p.strip() for p in args.plugins.split(",") if p.strip()]
    unknown = [p for p in selected if available and p not in available]
    if unknown:
        warn(f"not in the catalog: {', '.join(unknown)} (known: {', '.join(available) or 'none'})")
    path = apply_settings(project_settings_path(args.shared), cfg, enable=selected)
    info(f"Enabled {selected} in {path}")
    info("Run /reload-plugins (or start a new session) to load them.")


def cmd_enable(args):
    cfg = load_config()
    path = apply_settings(project_settings_path(args.shared), cfg, enable=args.plugins)
    info(f"Enabled {args.plugins} in {path}. Run /reload-plugins.")


def cmd_disable(args):
    cfg = load_config()
    path = apply_settings(project_settings_path(args.shared), cfg, disable=args.plugins)
    info(f"Disabled {args.plugins} in {path}. Run /reload-plugins.")


# ---------------------------------------------------------------------------
# push (promote new OR sync existing, auto-detected) / pull
# ---------------------------------------------------------------------------

def _root_md_files(folder: Path) -> list[Path]:
    """Markdown files at the root of a folder (non-recursive, sorted). A skill always has at
    least one root .md (its definition — usually SKILL.md); a folder with none is just code.
    This is the signal that keeps auto-detection from matching arbitrary code directories."""
    if not folder.is_dir():
        return []
    return sorted(p for p in folder.glob("*.md") if p.is_file())


def _is_skill_dir(folder: Path) -> bool:
    """A folder qualifies as a skill source iff it has at least one root-level .md file."""
    return bool(_root_md_files(folder))


def _resolve_skill_md(folder: Path, md_name: str | None = None) -> Path | None:
    """Pick the file that is the skill's definition markdown inside a folder. An explicit
    md_name wins; otherwise SKILL.md; otherwise the sole root-level .md. Returns None when
    there is no root .md, or several and none is SKILL.md (ambiguous — the caller must pick)."""
    if md_name:
        p = folder / md_name
        return p if p.is_file() else None
    smd = folder / "SKILL.md"
    if smd.is_file():
        return smd
    mds = _root_md_files(folder)
    return mds[0] if len(mds) == 1 else None


def _resolve_skill_src(name: str, from_dir: str | None = None) -> Path:
    """Locate the project-side skill directory to publish. A skill is a directory named <name>
    holding at least one root-level .md file (its definition — usually SKILL.md, sometimes a
    differently-named .md), so authoring isn't locked to one layout: we search an explicit
    --from, the canonical project dir, a plain folder in the cwd, the user's personal skills
    dir, a flat skills/ repo, and the cwd itself. A folder with no root .md is treated as code,
    not a skill, to avoid false positives. Folders with a real SKILL.md win across all
    locations; we only fall back to a differently-named root .md if none has SKILL.md. Dies
    listing everywhere it looked if nothing qualifies."""
    cwd = Path.cwd()
    home_skills = Path(os.path.expanduser("~/.claude/skills"))
    cands: list[Path] = []
    if from_dir:
        fd = expand(from_dir)
        cands += [fd, fd / name]            # --from may be the skill dir itself or its parent
    cands += [
        cwd / ".claude" / "skills" / name,  # canonical project skill
        cwd / name,                         # a plain folder in the current directory
        home_skills / name,                 # personal (~/.claude/skills) skill
        cwd / "skills" / name,              # flat skills repo
    ]
    if cwd.name == name:
        cands.append(cwd)                   # standing inside the skill's own folder
    ordered: list[Path] = []
    for c in cands:
        if c not in ordered:
            ordered.append(c)
    for c in ordered:                       # prefer a real SKILL.md anywhere over a misnamed .md
        if (c / "SKILL.md").is_file():
            return c
    for c in ordered:                       # fall back to any folder with a root-level .md
        if _is_skill_dir(c):
            return c
    looked = "\n  - ".join(str(c) for c in ordered)
    die(f"no skill named '{name}' found (a skill is a folder with at least one root-level .md "
        f"file, usually SKILL.md). Looked in:\n  - {looked}\n"
        f"Pass --from <dir> to point at it explicitly.")


def _dirs_equal(a: Path, b: Path) -> bool:
    """True if two skill directories have identical files and contents. Decided in-process
    (filecmp), so push's "no changes -> no-op" idempotency never depends on an external
    `diff` binary being installed."""
    if not a.exists() or not b.exists():
        return False
    af = {p.relative_to(a) for p in a.rglob("*") if p.is_file()}
    bf = {p.relative_to(b) for p in b.rglob("*") if p.is_file()}
    if af != bf:
        return False
    return all(filecmp.cmp(a / r, b / r, shallow=False) for r in af)


def _materialize_skill(src: Path, dst: Path, md_name: str):
    """Copy a skill dir src -> dst, ensuring its definition markdown lands as SKILL.md (Claude
    Code only loads SKILL.md). Scripts and supporting files are copied unchanged; the user's
    source is never modified (only this copy is renamed)."""
    shutil.copytree(src, dst)
    if md_name != "SKILL.md":
        (dst / md_name).replace(dst / "SKILL.md")


def cmd_push(args):
    cfg = load_config()
    src = _resolve_skill_src(args.skill, args.from_dir)

    # Which file in src is the skill definition? Explicit --md wins, else SKILL.md, else the
    # sole root-level .md. Refuse to guess when several root .md exist and none is SKILL.md.
    md = _resolve_skill_md(src, args.md)
    if md is None:
        if args.md:
            die(f"--md '{args.md}' is not a file in {src}.")
        roots = _root_md_files(src)
        if not roots:
            die(f"{src} has no skill markdown (expected SKILL.md or a root-level .md file).")
        die(f"AMBIGUOUS-MD: {src} has multiple root .md files and no SKILL.md: "
            f"{', '.join(p.name for p in roots)}. Re-run with --md <file> to name the skill's.")
    md_name = md.name

    # Deterministic guard: never publish a malformed skill, even if asked to.
    errs, warns, _ = _check_skill_md(src, md_name)
    for w in warns:
        warn(w)
    if errs:
        die("this skill would be broken once published:\n  - " + "\n  - ".join(errs)
            + "\nFix it (the skill-creator skill can help), then retry.")
    if md_name != "SKILL.md":
        info(f"Note: '{md_name}' will be published as SKILL.md (Claude Code only loads skills "
             f"from SKILL.md). Your local file is left unchanged.")

    matches = _find_plugins_for_skill(cfg, args.skill)

    if len(matches) > 1:
        # Ambiguous: this skill name is central in several plugins. Don't guess — the skill
        # layer turns this into an AskUserQuestion and re-runs with the chosen --plugin.
        if args.plugin in matches:
            plugin, mode = args.plugin, "update"
        else:
            die(f"AMBIGUOUS: '{args.skill}' exists in multiple plugins: "
                f"{', '.join(matches)}. Re-run with --plugin <one of those> to pick.")
    elif matches:
        existing = matches[0]
        if args.plugin and args.plugin != existing:
            die(f"'{args.skill}' already lives in plugin '{existing}'. Re-run without "
                f"--plugin to update it there, or remove it first.")
        plugin, mode = existing, "update"
    else:
        if not args.plugin:
            die(f"'{args.skill}' isn't central yet. Name the target plugin: "
                f"skillctl push {args.skill} --plugin <name>")
        plugin, mode = args.plugin, "new"

    if not _entry(cfg, plugin):
        if mode != "new":
            die(f"plugin '{plugin}' not in marketplace.json")
        info(f"Plugin '{plugin}' doesn't exist yet — creating and registering it.")
        _create_plugin(cfg, plugin, None)

    dst = plugin_dir(cfg, plugin) / "skills" / args.skill

    # Stage the exact bytes we'd publish (the skill's .md renamed to SKILL.md) once, then use
    # the same staged copy for the equality check, the diff, and the write — so all three
    # agree on the rename and a re-push of an unchanged skill stays a clean no-op.
    with tempfile.TemporaryDirectory() as td:
        staged = Path(td) / args.skill
        _materialize_skill(src, staged, md_name)

        if mode == "update":
            # Equality is decided in-process (not via the diff binary) so a re-run on an
            # unchanged skill is always a clean no-op — no version churn, no empty commit.
            if _dirs_equal(staged, dst) and not args.force:
                info("No differences — central copy already matches.")
                n = _unpushed_count(cfg)
                if n:
                    info(f"Note: {n} local commit(s) are not on the remote yet (a previous push "
                         f"may have failed). Flush them with: git -C {repo_path(cfg)} push")
                return
            if have("diff"):  # for the user's benefit only; the decision above is authoritative
                d = run(["diff", "-ru", str(dst), str(staged)], check=False, quiet=True)
                if d.stdout.strip():
                    info("Changes to push up:\n" + d.stdout)
            if args.dry_run:
                info("(dry run — nothing written)")
                return
            shutil.rmtree(dst)
        else:
            if args.dry_run:
                info(f"(dry run) would create {dst}")
                return
            if dst.exists():
                if not args.force:
                    die(f"{dst} already exists. Pass --force to overwrite.")
                shutil.rmtree(dst)
            dst.parent.mkdir(parents=True, exist_ok=True)
        shutil.copytree(staged, dst)

    newver = _bump_version(cfg, plugin)
    verb = "Update" if mode == "update" else "Add"
    ok = _commit_push(cfg, args.message or f"{verb} skill '{args.skill}' in {plugin} (v{newver})",
                      [str(plugin_dir(cfg, plugin)), str(marketplace_json_path(cfg))])
    if not args.no_refresh:
        _refresh(cfg)

    info(f"\n{'Updated' if mode == 'update' else 'Published'} '{args.skill}' in '{plugin}' "
         f"(now v{newver}). Invoked as /{plugin}:{args.skill}.")
    if not ok:
        info("WARNING: git push did NOT succeed (see error above). The change is committed "
             "locally but is NOT on the remote yet.")
    info("Run /reload-plugins to use it in this session.")
    if plugin not in project_enabled(cfg):
        info(f"This project doesn't enable '{plugin}' yet: skillctl enable {plugin}")


def cmd_pull(args):
    cfg = load_config()
    plugin = args.plugin
    if not plugin:
        matches = _find_plugins_for_skill(cfg, args.skill)
        if len(matches) > 1:
            die(f"AMBIGUOUS: '{args.skill}' exists in multiple plugins: "
                f"{', '.join(matches)}. Re-run with --plugin <one of those>.")
        plugin = matches[0] if matches else None
    if not plugin:
        die(f"'{args.skill}' not found in the central repo.")
    src = plugin_dir(cfg, plugin) / "skills" / args.skill
    dst = Path.cwd() / ".claude" / "skills" / args.skill
    dst.parent.mkdir(parents=True, exist_ok=True)
    if dst.exists():
        if not args.force:
            die(f"{dst} already exists. Pass --force to overwrite.")
        shutil.rmtree(dst)
    shutil.copytree(src, dst)
    info(f"Pulled '{args.skill}' from '{plugin}' -> {dst} for local iteration.")
    info(f"Edit it, then push changes back with: skillctl push {args.skill}")


# ---------------------------------------------------------------------------
# new-plugin / remove
# ---------------------------------------------------------------------------

def _create_plugin(cfg: dict, name: str, desc: str | None) -> Path:
    if not re.fullmatch(r"[a-z0-9][a-z0-9-]*", name):
        die("plugin name must be lowercase letters, digits, and hyphens")
    pdir = plugins_base(cfg) / name
    if pdir.exists():
        die(f"{pdir} already exists")
    (pdir / ".claude-plugin").mkdir(parents=True)
    (pdir / "skills").mkdir(parents=True)
    # version is intentionally NOT written here — it lives in marketplace.json
    write_json(pdir / ".claude-plugin" / "plugin.json",
               {"name": name, "description": desc or f"{name} skills"}, backup=False)
    (pdir / "skills" / ".gitkeep").write_text("")

    mpath = marketplace_json_path(cfg)
    mkt = read_json(mpath, {"name": cfg["marketplace"], "owner": {"name": ""}, "plugins": []})
    mkt.setdefault("plugins", [])
    if any(p.get("name") == name for p in mkt["plugins"]):
        die(f"'{name}' already in marketplace.json")
    mkt["plugins"].append({
        "name": name,
        "source": rel_source(cfg, name),
        "description": desc or f"{name} skills",
        "version": "0.1.0",
    })
    write_json(mpath, mkt, backup=False)
    return pdir


def cmd_new_plugin(args):
    cfg = load_config()
    pdir = _create_plugin(cfg, args.name, args.description)
    ok = _commit_push(cfg, args.message or f"Add plugin '{args.name}'",
                      [str(pdir), str(marketplace_json_path(cfg))])
    if not args.no_refresh:
        _refresh(cfg)
    info(f"Created and registered plugin '{args.name}'.")
    info(f"Author skills for it with the native skill-creator skill, then: "
         f"skillctl push <skill> --plugin {args.name}")
    if not ok:
        info("WARNING: push failed — committed locally only.")


def cmd_remove_skill(args):
    cfg = load_config()
    plugin = args.plugin
    if not plugin:
        matches = _find_plugins_for_skill(cfg, args.skill)
        if len(matches) > 1:
            die(f"AMBIGUOUS: '{args.skill}' exists in multiple plugins: "
                f"{', '.join(matches)}. Re-run with --plugin <one of those>.")
        plugin = matches[0] if matches else None
    if not plugin:
        die(f"'{args.skill}' not found in any central plugin.")
    dst = plugin_dir(cfg, plugin) / "skills" / args.skill
    if not dst.exists():
        die(f"{dst} does not exist")
    if not args.force:
        die(f"This deletes {dst} and pushes the removal. Re-run with --force to confirm.")
    shutil.rmtree(dst)
    newver = _bump_version(cfg, plugin)
    ok = _commit_push(cfg, args.message or f"Remove skill '{args.skill}' from {plugin} (v{newver})",
                      [str(plugin_dir(cfg, plugin)), str(marketplace_json_path(cfg))])
    if not args.no_refresh:
        _refresh(cfg)
    info(f"Removed '{args.skill}' from '{plugin}' (now v{newver}).")
    sdir = plugin_dir(cfg, plugin) / "skills"
    remaining = [s for s in sdir.glob("*") if s.is_dir()] if sdir.exists() else []
    if not remaining:
        info(f"note: '{plugin}' has no skills left — consider removing it: "
             f"skillctl remove-plugin {plugin} --force")
    if not ok:
        info("WARNING: push failed — committed locally only.")


def cmd_remove_plugin(args):
    cfg = load_config()
    name = args.plugin
    pdir = plugin_dir(cfg, name)
    if not _entry(cfg, name) and not pdir.exists():
        die(f"plugin '{name}' not found")
    if not args.force:
        die(f"This deletes {pdir}, unregisters it, and pushes. Re-run with --force to confirm.")
    if pdir.exists():
        shutil.rmtree(pdir)
    mpath = marketplace_json_path(cfg)
    mkt = read_json(mpath, {})
    mkt["plugins"] = [p for p in mkt.get("plugins", []) if p.get("name") != name]
    write_json(mpath, mkt, backup=False)

    us = read_json(USER_SETTINGS, {})
    key = f"{name}@{cfg['marketplace']}"
    if (us.get("enabledPlugins") or {}).get(key) is not None:
        us["enabledPlugins"].pop(key, None)
        write_json(USER_SETTINGS, us)
        info(f"Removed {key} from user settings.")

    ok = _commit_push(cfg, args.message or f"Remove plugin '{name}'", [str(pdir), str(mpath)])
    if not args.no_refresh:
        _refresh(cfg)
    info(f"Removed plugin '{name}'.")
    info("Note: project-level enablement in other repos must be cleaned up manually.")
    if not ok:
        info("WARNING: push failed — committed locally only.")


# ---------------------------------------------------------------------------
# status (catalog + enablement + health)
# ---------------------------------------------------------------------------

def cmd_status(args):
    cfg = load_config(required=False)
    if not cfg:
        info("skill-manager is not configured.")
        info("Run /skill-manager:init  (skillctl init --repo <owner/name> --path <checkout>).")
        return

    enabled = project_enabled(cfg)
    info(f"Marketplace: {cfg['marketplace']}  ({cfg['repoSlug']})")
    info(f"Repo:        {cfg['repoPath']}  (plugins in '{cfg.get('pluginsDir') or '.'}')")
    info(f"Project:     {Path.cwd()}\n")

    cat = catalog(cfg)
    for e in cat:
        name = e["name"]
        mark = "[on] " if name in enabled else "[  ] "
        sdir = plugin_dir(cfg, name) / "skills"
        skills = sorted(s.name for s in sdir.glob("*") if s.is_dir()) if sdir.exists() else []
        info(f"{mark}{name}  v{e.get('version', '?')}  —  {e.get('description', '')}")
        for s in skills:
            info(f"        /{name}:{s}")
    if not cat:
        info("(no plugins in the catalog yet — create one with skillctl new-plugin <name>)")

    info("\nHealth:")
    _health(cfg, fix=getattr(args, "fix", False))


def _health(cfg: dict, fix: bool = False):
    """Health check. With fix=True, auto-repair the failures that are safe to fix without
    new input from the user: marketplace registration and user-scope plugin enablement.
    Failures that need a decision (missing checkout, no origin, no claude CLI, unpushed
    commits) are reported with a hint, never silently actioned."""
    fixed: list[str] = []
    fixable_failing: list[str] = []

    def check(label, condition, hint="", fixable=False):
        status = "ok " if condition else "FAIL"
        line = f"  [{status}] {label}"
        if not condition and hint:
            line += f"\n         -> {hint}"
        info(line)
        if not condition and fixable:
            fixable_failing.append(label)

    repo = repo_path(cfg)
    check(f"checkout exists ({repo})", (repo / ".git").exists(),
          f"clone it or fix repoPath in {CONFIG_PATH}")
    if (repo / ".git").exists():
        rem = run(["git", "-C", str(repo), "remote"], check=False, quiet=True).stdout.split()
        check("origin remote configured", "origin" in rem,
              "git remote add origin <url>  (needed to push skills)")
        if "origin" in rem:
            n = _unpushed_count(cfg)
            if n is not None:
                check("local in sync with origin", n == 0,
                      f"{n} commit(s) not pushed yet — run: git -C {repo} push")
    check("marketplace.json present", marketplace_json_path(cfg).exists())

    have_claude = have("claude")
    check("'claude' CLI on PATH", have_claude,
          "install Claude Code so headless plugin commands work")
    if have_claude:
        def _registered():
            ml = run(["claude", "plugin", "marketplace", "list"], check=False, quiet=True)
            return cfg["marketplace"] in (ml.stdout or "")
        registered = _registered()
        if not registered and fix:
            _ensure_registered(cfg)
            if _registered():
                registered = True
                fixed.append(f"registered marketplace '{cfg['marketplace']}'")
        check(f"marketplace '{cfg['marketplace']}' registered", registered,
              f"claude plugin marketplace add {cfg['repoSlug']}", fixable=True)

    for p in cfg.get("userPlugins", []):
        key = f"{p}@{cfg['marketplace']}"
        enabled = (read_json(USER_SETTINGS, {}).get("enabledPlugins") or {}).get(key) is True
        if not enabled and fix:
            apply_settings(USER_SETTINGS, cfg, enable=[p])
            if (read_json(USER_SETTINGS, {}).get("enabledPlugins") or {}).get(key) is True:
                enabled = True
                fixed.append(f"enabled {key} at user scope")
        check(f"user-enabled: {key}", enabled,
              f"skillctl enable {p}  (or re-run init)", fixable=True)

    if fix:
        if fixed:
            info("\nFixed:")
            for f in fixed:
                info(f"  - {f}")
            info("Run /reload-plugins to apply.")
        else:
            info("\nNothing to auto-fix — any remaining failures need a manual step (see hints).")
    elif fixable_failing:
        info(f"\n-> {len(fixable_failing)} issue(s) above are auto-fixable — re-run with "
             f"--fix  (e.g. /skill-manager:status --fix).")


# ---------------------------------------------------------------------------
# validate (CI-friendly) / refresh
# ---------------------------------------------------------------------------

def _frontmatter(text: str) -> dict | None:
    """Minimal YAML frontmatter parser (key: value, top level only). Stdlib only."""
    if not text.startswith("---"):
        return None
    end = text.find("\n---", 3)
    if end == -1:
        return None
    out = {}
    for line in text[3:end].strip("\n").splitlines():
        if not line.strip() or line.lstrip().startswith("#") or ":" not in line:
            continue
        k, v = line.split(":", 1)
        out[k.strip()] = v.strip().strip('"').strip("'")
    return out


def _check_skill_md(skill_dir: Path, md_name: str | None = None):
    """Deterministic lint of one skill directory. Returns (errors, warnings, frontmatter).
    Used both by `validate` and as a pre-publish guard in `push`, so a malformed skill can
    never be committed to the marketplace by mistake. md_name names the definition markdown
    when it isn't SKILL.md (push publishes it renamed to SKILL.md)."""
    smd = _resolve_skill_md(skill_dir, md_name)
    if smd is None:
        roots = _root_md_files(skill_dir)
        if not roots:
            return ([f"{skill_dir}: no skill markdown (expected SKILL.md or a root-level "
                     f".md file)"], [], None)
        return ([f"{skill_dir}: {len(roots)} root .md files and none named SKILL.md — name the "
                 f"skill's file with --md <file> (or rename it to SKILL.md)"], [], None)
    fm = _frontmatter(smd.read_text())
    if fm is None:
        return ([f"{smd}: missing or malformed YAML frontmatter"], [], None)
    errors: list[str] = []
    warnings: list[str] = []
    desc = fm.get("description", "")
    if not desc:
        errors.append(f"{smd}: no 'description' in frontmatter (it's how the skill triggers)")
    elif len(desc) > 1536:
        warnings.append(f"{smd}: description is {len(desc)} chars (listing cap is 1536)")
    nm = fm.get("name")
    if nm and nm != skill_dir.name:
        warnings.append(f"{smd}: frontmatter name '{nm}' != directory '{skill_dir.name}' "
                        f"(skills are invoked by directory name)")
    return (errors, warnings, fm)


def cmd_validate(args):
    cfg = load_config(required=False)
    repo = repo_path(cfg) if cfg else Path.cwd()
    mpath = repo / ".claude-plugin" / "marketplace.json"
    errors: list[str] = []
    warnings: list[str] = []

    if not mpath.exists():
        die(f"no marketplace.json at {mpath}")
    declared = read_json(mpath, {}).get("plugins", [])
    if not declared:
        warnings.append("marketplace.json declares no plugins")

    for entry in declared:
        name = entry.get("name")
        src = entry.get("source", f"./{name}")
        pdir = repo / (src[2:] if src.startswith("./") else src)
        if not entry.get("version"):
            warnings.append(f"plugin '{name}': no version in marketplace.json entry")
        if not pdir.exists():
            errors.append(f"plugin '{name}': source dir {pdir} does not exist")
            continue
        man = pdir / ".claude-plugin" / "plugin.json"
        if not man.exists():
            errors.append(f"plugin '{name}': missing {man}")
        else:
            m = read_json(man, {})
            if m.get("name") != name:
                warnings.append(f"plugin '{name}': plugin.json name is '{m.get('name')}'")
            if "version" in m:
                warnings.append(f"plugin '{name}': version should live in marketplace.json, "
                                f"not plugin.json")
        sdir = pdir / "skills"
        seen: set[str] = set()
        for skill in (sorted(sdir.glob("*")) if sdir.exists() else []):
            if not skill.is_dir():
                continue
            errs, warns, fm = _check_skill_md(skill)
            errors.extend(errs)
            warnings.extend(warns)
            sk = (fm or {}).get("name", skill.name)
            if sk in seen:
                errors.append(f"plugin '{name}': duplicate skill name '{sk}'")
            seen.add(sk)

    for w in warnings:
        info(f"  warn: {w}")
    if errors:
        for e in errors:
            print(f"  FAIL: {e}", file=sys.stderr)
        die(f"{len(errors)} error(s), {len(warnings)} warning(s)")
    info(f"OK — {len(declared)} plugin(s) valid, {len(warnings)} warning(s)")


def cmd_refresh(args):
    _refresh(load_config())


def _refresh(cfg: dict):
    """Best-effort update of the marketplace clone, then tell the user the two in-session
    commands to pick the change up. A CLI/subprocess `marketplace update` does NOT refresh a
    running session, and custom marketplaces don't auto-refresh — so in-session the user must
    run the marketplace-update slash command and then reload."""
    mkt = cfg["marketplace"]
    if have("claude"):
        run(["claude", "plugin", "marketplace", "update", mkt], check=False)
    info(f"Custom marketplaces don't reliably auto-update (even in new sessions), so after "
         f"EVERY change run these two commands in-session to pick it up:")
    info(f"  /plugin marketplace update {mkt}")
    info(f"  /reload-plugins")


# ---------------------------------------------------------------------------
# arg parsing
# ---------------------------------------------------------------------------

def _add_shared(p):
    p.add_argument("--shared", action="store_true",
                   help="write to .claude/settings.json (committed) instead of settings.local.json")


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="skillctl", description=__doc__,
                                formatter_class=argparse.RawDescriptionHelpFormatter)
    sub = p.add_subparsers(dest="cmd", required=True)

    i = sub.add_parser("init", help="one-time setup against your local checkout")
    i.add_argument("--repo", help="owner/name of the marketplace repo (auto-detected from origin if omitted)")
    i.add_argument("--path", help="path to your local checkout (default: cwd; clones here if --repo given and missing)")
    i.add_argument("--marketplace", help="marketplace name (default: marketplace.json name, else repo name)")
    i.add_argument("--plugins-dir", help="dir under the repo where plugins live (default: auto-detect; '.' for root)")
    i.add_argument("--user-plugins", help="comma list to enable for all projects (default none)")
    i.set_defaults(func=cmd_init)

    c = sub.add_parser("configure", help="choose which plugins this project uses")
    c.add_argument("--plugins", help="comma list to enable; omit to print the catalog")
    _add_shared(c)
    c.set_defaults(func=cmd_configure)

    e = sub.add_parser("enable", help="enable plugin(s) in this project")
    e.add_argument("plugins", nargs="+")
    _add_shared(e)
    e.set_defaults(func=cmd_enable)

    d = sub.add_parser("disable", help="disable plugin(s) in this project")
    d.add_argument("plugins", nargs="+")
    _add_shared(d)
    d.set_defaults(func=cmd_disable)

    pu = sub.add_parser("push", help="publish a project skill central, or sync edits up")
    pu.add_argument("skill")
    pu.add_argument("--from", dest="from_dir",
                    help="dir to read the skill from (default: search .claude/skills/, a folder "
                         "in cwd, ~/.claude/skills/, skills/)")
    pu.add_argument("--md", help="which root .md is the skill definition (default: SKILL.md, "
                                 "else the sole root .md; published as SKILL.md)")
    pu.add_argument("--plugin", help="target plugin (required only for a brand-new skill)")
    pu.add_argument("--message", "-m")
    pu.add_argument("--force", action="store_true")
    pu.add_argument("--dry-run", action="store_true")
    pu.add_argument("--no-refresh", action="store_true")
    pu.set_defaults(func=cmd_push)

    pl = sub.add_parser("pull", help="copy a central skill down into this project")
    pl.add_argument("skill")
    pl.add_argument("--plugin")
    pl.add_argument("--force", action="store_true")
    pl.set_defaults(func=cmd_pull)

    npl = sub.add_parser("new-plugin", help="scaffold + register a new plugin")
    npl.add_argument("name")
    npl.add_argument("--description")
    npl.add_argument("--message", "-m")
    npl.add_argument("--no-refresh", action="store_true")
    npl.set_defaults(func=cmd_new_plugin)

    rs = sub.add_parser("remove-skill", help="delete a skill from a central plugin")
    rs.add_argument("skill")
    rs.add_argument("--plugin", help="override auto-detected plugin")
    rs.add_argument("--message", "-m")
    rs.add_argument("--force", action="store_true")
    rs.add_argument("--no-refresh", action="store_true")
    rs.set_defaults(func=cmd_remove_skill)

    rp = sub.add_parser("remove-plugin", help="delete a plugin and unregister it")
    rp.add_argument("plugin")
    rp.add_argument("--message", "-m")
    rp.add_argument("--force", action="store_true")
    rp.add_argument("--no-refresh", action="store_true")
    rp.set_defaults(func=cmd_remove_plugin)

    st = sub.add_parser("status", help="catalog + project enablement + health")
    st.add_argument("--fix", action="store_true",
                    help="auto-repair fixable health issues (re-register marketplace, re-enable user plugins)")
    st.set_defaults(func=cmd_status)
    sub.add_parser("validate", help="lint the repo (CI-friendly)").set_defaults(func=cmd_validate)
    sub.add_parser("refresh", help="update the marketplace so changes are picked up").set_defaults(func=cmd_refresh)

    vb = sub.add_parser("version-bump", help="patch-bump a plugin in marketplace.json")
    vb.add_argument("plugin")
    vb.set_defaults(func=cmd_version_bump)

    return p


def main():
    args = build_parser().parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
